{
  "name": "tu-ia-me-aburre",
  "version": "0.2.0",
  "private": true,
  "description": "Un juego donde humanos se hacen pasar por IA. Inspirado en 'Your AI Slop Bores Me'. Look: habitación de universitario.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,magenta \"node --watch server.js\" \"vite\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "start": "node server.js",
    "server": "node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^4.19.2",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
